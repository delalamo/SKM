#!/usr/bin/env python3
from __future__ import annotations

"""
pre-commit hook — auto-stamp `created` and `modified` in note frontmatter.

Rules:
  • Newly-added file  (git status A): set both `created` and `modified`
    to the current commit time.  Existing `created` is never overwritten.
  • Modified file     (git status M): update `modified` to the current
    commit time.  `created` is left untouched (added if absent, though).
  • Only files inside content/notes/ and content/MOCs/ are touched.
  • Files without a YAML frontmatter block are left alone.

Installation (one-time, from repo root):
    git config core.hooksPath .githooks
"""

import re
import subprocess
import sys
from datetime import datetime
from pathlib import Path

# ── helpers ────────────────────────────────────────────────────────────────────

FRONTMATTER_RE = re.compile(r"\A---\n(.*?)\n---\n", re.DOTALL)
FIELD_RE        = re.compile(r"^(created|modified):\s*.+$", re.MULTILINE)

WATCHED_PREFIXES = ("content/notes/", "content/MOCs/")


def now_iso() -> str:
    return datetime.now().strftime("%Y-%m-%dT%H:%M:%S")


def repo_root() -> Path:
    result = subprocess.run(
        ["git", "rev-parse", "--show-toplevel"],
        capture_output=True, text=True, check=True,
    )
    return Path(result.stdout.strip())


def staged_files() -> list[tuple[str, str]]:
    """Return list of (status, repo-relative-path) for staged .md files."""
    result = subprocess.run(
        ["git", "diff", "--cached", "--name-status", "--diff-filter=ACM"],
        capture_output=True, text=True, check=True,
    )
    entries = []
    for line in result.stdout.splitlines():
        parts = line.split("\t", 1)
        if len(parts) != 2:
            continue
        status, path = parts[0].strip(), parts[1].strip()
        if path.endswith(".md") and any(path.startswith(p) for p in WATCHED_PREFIXES):
            entries.append((status, path))
    return entries


def stamp(text: str, status: str, ts: str) -> str | None:
    """
    Return the updated file text, or None if no change is needed.

    status:
      'A' (Added)    → set created + modified (never overwrite existing created)
      'M' (Modified) → update modified; add created if missing
      'C' (Copied)   → treat like Added
    """
    m = FRONTMATTER_RE.match(text)
    if not m:
        return None  # no YAML block — skip

    fm_body = m.group(1)
    after   = text[m.end():]

    has_created  = bool(re.search(r"^created:", fm_body, re.MULTILINE))
    has_modified = bool(re.search(r"^modified:", fm_body, re.MULTILINE))

    changed = False
    new_fm  = fm_body

    if status in ("A", "C"):
        # Add created if absent
        if not has_created:
            new_fm  += f'\ncreated: "{ts}"'
            changed  = True
        # Add or replace modified
        if has_modified:
            new_fm, n = re.subn(r'^modified:\s*.+$', f'modified: "{ts}"', new_fm, flags=re.MULTILINE)
            changed = changed or bool(n)
        else:
            new_fm += f'\nmodified: "{ts}"'
            changed  = True

    else:  # 'M'
        # Add created if missing
        if not has_created:
            new_fm += f'\ncreated: "{ts}"'
            changed  = True
        # Update modified
        if has_modified:
            new_fm, n = re.subn(r'^modified:\s*.+$', f'modified: "{ts}"', new_fm, flags=re.MULTILINE)
            changed = changed or bool(n)
        else:
            new_fm += f'\nmodified: "{ts}"'
            changed  = True

    if not changed:
        return None

    return f"---\n{new_fm}\n---\n{after}"


# ── main ───────────────────────────────────────────────────────────────────────

def main() -> int:
    try:
        root = repo_root()
        files = staged_files()
    except subprocess.CalledProcessError as e:
        print(f"[pre-commit] git error: {e}", file=sys.stderr)
        return 1

    if not files:
        return 0

    ts      = now_iso()
    amended = []

    for status, rel_path in files:
        abs_path = root / rel_path
        try:
            original = abs_path.read_text("utf-8")
        except OSError:
            continue

        updated = stamp(original, status, ts)
        if updated is None:
            continue

        abs_path.write_text(updated, "utf-8")
        subprocess.run(["git", "add", str(abs_path)], check=True)
        amended.append(f"  {status}  {rel_path}")

    if amended:
        print(f"[pre-commit] stamped dates on {len(amended)} file(s):")
        for line in amended:
            print(line)

    return 0


if __name__ == "__main__":
    sys.exit(main())
